# Supabase — copy this file to ".env" and fill in your project values.
# Find them in Supabase Studio → Project Settings → API.
# NOTE: only the "anon public" key goes here (it is safe for the browser).
# Never put the "service_role" key in the frontend.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
