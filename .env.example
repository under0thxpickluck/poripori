# Supabase — browser client config. Copy this file to `.env` and fill in values.
# These are the browser-safe PUBLIC values (project URL + publishable/anon key).
# NEVER put the "service_role" / secret key here — it must not ship to the frontend.
#
# Find them in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
